# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/mgstore
SPRING_DATASOURCE_USERNAME=mgstore_user
SPRING_DATASOURCE_PASSWORD=your_secure_password

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-change-this-in-production
JWT_EXPIRATION=86400000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Culqi
CULQI_PUBLIC_KEY=pk_live_your_public_key
CULQI_SECRET_KEY=sk_live_your_secret_key
CULQI_API_URL=https://api.culqi.com/v2

# WhatsApp Cloud API
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER=+51999999999
