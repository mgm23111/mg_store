# Database Configuration
DB_NAME=mgstore
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# Spring Profile (dev, prod)
SPRING_PROFILE=prod

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-256-bits

# Culqi Configuration
CULQI_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
CULQI_SECRET_KEY=sk_test_xxxxxxxxxxxx
VITE_CULQI_PUBLIC_KEY=pk_test_xxxxxxxxxxxx

# WhatsApp Cloud API Configuration
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,http://127.0.0.1,http://127.0.0.1:3000,http://127.0.0.1:5173,https://yourdomain.com

# Rate Limiting (Production)
SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_RATE_LIMIT_LOGIN_MAX_REQUESTS=5
SECURITY_RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
SECURITY_RATE_LIMIT_CHECKOUT_MAX_REQUESTS=20
SECURITY_RATE_LIMIT_CHECKOUT_WINDOW_SECONDS=60
SECURITY_RATE_LIMIT_PAYMENT_MAX_REQUESTS=10
SECURITY_RATE_LIMIT_PAYMENT_WINDOW_SECONDS=60

# API URLs
VITE_API_URL=http://localhost:8891/api
APP_PUBLIC_API_BASE_URL=http://localhost:8891/api
APP_UPLOAD_BASE_DIR=uploads

# Port Configuration
BACKEND_PORT=8891
FRONTEND_PORT=80

# Monitoring (Grafana)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
